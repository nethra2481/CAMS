generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}



model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  role           String    @default("STUDENT")
  name           String
  registerNumber String?   @unique
  mobile         String?
  department     String?
  year           String?
  section        String?
  batch          String?
  linkedin       String?
  github         String?
  resume         String?
  skills         String?
  aboutMe        String?
  profilePic     String?
  
  achievements   Achievement[] @relation("StudentAchievements")
  teamInvites    TeamMember[]
  
  announcements  Announcement[] @relation("FacultyAnnouncements")
  eventRegistrations EventRegistration[] @relation("StudentRegistrations")
  notifications  Notification[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Achievement {
  id                String            @id @default(cuid())
  title             String
  organizer         String
  category          String
  level             String
  mode              String
  startDate         DateTime
  endDate           DateTime?
  location          String?
  isTeam            Boolean           @default(false)
  teamName          String?
  problemStatement  String?
  techUsed          String?
  
  result            String
  description       String
  rank              String?
  prizeAmount       String?
  skillsUsed        String?
  
  status            String            @default("PENDING")
  facultyRemark     String?
  aiMotivation      String?
  
  // NEW: Dynamic form data
  dynamicData       String?
  
  // NEW: Points awarded for Placement Readiness
  scoreAwarded      Int               @default(0)
  
  proofFiles        ProofFile[]
  teamMembers       TeamMember[]
  history           AchievementHistory[]
  successStory      SuccessStory?
  
  studentId         String
  student           User              @relation("StudentAchievements", fields: [studentId], references: [id])
  
  announcementId    String?
  announcement      Announcement?     @relation("EventAchievements", fields: [announcementId], references: [id])
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model FormTemplate {
  id              String   @id @default(cuid())
  category        String   @unique // e.g. "Hackathon", "CTF"
  schemaJson      String   // JSON string defining fields, types, and validation
  readinessPoints Int      @default(0) // Default placement readiness points for this category
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TeamMember {
  id              String      @id @default(cuid())
  achievementId   String
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  // For internal students
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  
  // For external students
  externalName    String?
  externalDept    String?
  
  hasAccepted     Boolean     @default(false)
}

model ProofFile {
  id            String      @id @default(cuid())
  url           String
  type          String // PDF, JPG, etc.
  name          String
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
}

model Announcement {
  id              String   @id @default(cuid())
  title           String
  type            String   // "EVENT", "DEADLINE", "OPPORTUNITY"
  description     String
  targetDate      DateTime? 
  link            String?
  
  // Faculty Controls
  acceptSubmissions Boolean @default(true)
  allowTeamEntries  Boolean @default(true)
  visibilityLevel   String  @default("DEPARTMENT") // PRIVATE, BATCH, DEPARTMENT
  targetBatch       String? 
  isLocked          Boolean @default(false)
  
  // Pre-fill Data for Students
  eventCategory     String?
  eventLevel        String?
  eventMode         String?
  eventOrganizer    String?
  
  // Custom registration form for internal events
  registrationSchema String? // JSON array of FormField
  
  postedById      String
  postedBy        User     @relation("FacultyAnnouncements", fields: [postedById], references: [id])
  
  registrations   EventRegistration[]
  achievements    Achievement[] @relation("EventAchievements")
  feedPosts       FeedPost[]
  
  createdAt       DateTime @default(now())
}

model EventRegistration {
  id              String   @id @default(cuid())
  status          String   @default("INTERESTED")
  
  // JSON string containing answers to registrationSchema
  dynamicData     String?
  
  studentId       String
  student         User     @relation("StudentRegistrations", fields: [studentId], references: [id])
  
  announcementId  String
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  
  @@unique([studentId, announcementId])
}

model SuccessStory {
  id              String   @id @default(cuid())
  achievementId   String   @unique
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  whatWeBuilt     String
  challengesFaced String
  lessonsLearned  String
  tipsForJuniors  String
  
  createdAt       DateTime @default(now())
}

model AchievementHistory {
  id              String   @id @default(cuid())
  achievementId   String
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  title           String
  description     String
  result          String
  status          String
  facultyRemark   String?
  
  savedAt         DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())
}

model FeedPost {
  id              String   @id @default(cuid())
  title           String
  content         String
  images          String?  // JSON array string
  
  announcementId  String?
  announcement    Announcement? @relation(fields: [announcementId], references: [id])
  
  postedById      String
  
  createdAt       DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
